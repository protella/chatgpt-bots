# secrets — must stay a wildcard. A bare `.env` rule matches ONLY that exact name:
# siblings like `.env.bak-keep.txt` sail straight past it. Ignore anything env-shaped
# by default and add an explicit negation for the rare file meant to be published.
.env*
!.env.example

# VSCode
.vscode/

# lib64 and venv config
lib64
pyvenv.cfg

#v-environment binaries
bin/

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# Translations
*.mo
*.pot

# Django stuff:
local_settings.py
db.sqlite3
db.sqlite3-journal

# Flask stuff:
instance/
.webassets-cache

# Scrapy stuff:
.scrapy

# Sphinx documentation
docs/_build/

# PyBuilder
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if having platform-specific dependencies or dependencies
#   having no cross-platform support, pipenv may install dependencies that don't work, or not
#   install all needed dependencies.
#Pipfile.lock

# PEP 582; used by e.g. github.com/David-OConnor/pyflow
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

# Environments (all .env* is ignored at the top of this file)
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Spyder project settings
.spyderproject
.spyproject

# Rope project settings
.ropeproject

# mkdocs documentation
/site

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# ruff
.ruff_cache/

# Pyre type checker
.pyre/

# Local logs — keep the directory, ignore everything written into it.
# Must stay `logs/*`: a blanket `logs/` rule excludes the directory itself, and
# git cannot re-include a file inside an excluded directory, which silently
# defeats the !logs/.gitkeep negation below.
logs/*
!logs/.gitkeep
*.log

# BMAD Method folders (local only) — matches .bmad-core/, .bmad-infrastructure-devops/
.bmad-*/

# Ignore the OpenAI API reference PDF so it is not tracked by git
API Reference - OpenAI API.pdf

# SQLite databases
data/*
!data/.gitkeep
!data/backups/
data/backups/*
!data/backups/.gitkeep
*.db
*.db-wal
*.db-shm

# Local-only reports, caches, and configs
metrics_reports/
mcp_config.json
mcp_config*.bak
.mcp.json
.channels_cache_v2.json
.users_cache.json

# Claude Code local settings (note: .claude/commands/** IS tracked)
.claude/settings.local.json

# Claude Image Paste screenshots
.cp-images/

# Slack app manifest (environment-specific; use slack_app_manifest.example.yml as template)
slack_app_manifest.yml

# Company-branded loading messages stay local (like .env) — the generic set is the committed default
status_messages/loading_messages.datassential.txt
