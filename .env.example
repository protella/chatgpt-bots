# =====================================================================
# 1) REQUIRED SETUP — credentials & entry points (the bot won't start
#    without these; set per environment)
# =====================================================================

# Slack Configuration
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_APP_TOKEN=xapp-your-slack-app-token
SETTINGS_SLASH_COMMAND=/chatgpt-settings  # Slash command for user settings modal

# OpenAI Configuration
OPENAI_KEY=sk-your-openai-api-key

# =====================================================================
# 2) WORKSPACE BRANDING & UX — customize for your org
# =====================================================================

# Slack Organization Info (optional - for system prompt)
SLACK_COMPANY_NAME=Your Company Name  # Used in system prompt for context
SLACK_COMPANY_WEBSITE=https://www.example.com  # Company website reference

# UI Configuration - Emoji codes for status indicators - YOU MUST CONFIGURE THESE ACCORDING TO YOUR OWN AVAILABLE EMOJIS
THINKING_EMOJI=:hourglass_flowing_sand:  # Reserved auxiliary indicator (kept for future use; status prefixes use CIRCLE_LOADER_EMOJI)
WEB_SEARCH_EMOJI=:web_search:  # Shows when performing web search
LOADING_ELLIPSE_EMOJI=:loading-ellipse:  # Alternative loading indicator
CIRCLE_LOADER_EMOJI=:circle-loader:  # Prefix on ALL status/progress indicators — use a Slack built-in (e.g. :hourglass_flowing_sand:) if your workspace has no custom loader emoji
ANALYZE_EMOJI=:analyze:  # Shows when analyzing images/documents
ERROR_EMOJI=:warning:  # Shows for errors

# --- Status indicator strings ---
# STATUS_LOADING_MESSAGES_FILE=status_messages/loading_messages.generic.txt  # Rotating "working" messages shown in the thread bubble: one per line, # comments ok. Default is the bundled generic set (100); point at your own file to brand them. Plain text only — no emoji.
# STATUS_LOADING_MESSAGES=crunching the data…,connecting the dots…  # Inline comma-separated alternative; takes precedence over the file when set.
# STATUS_LOADING_FALLBACK=working on it…  # Last-resort single status when no pool resolves.
# PIPELINE_MESSAGES_FILE=status_messages/pipeline_messages.txt  # Stage-keyed pipeline status variants ([stage] sections, one per line; a random variant is shown each time a stage runs).

# --- Assistant surface / agent split-view adapter ---
ENABLE_ASSISTANT_SURFACE=true  # Greeting + suggested prompts on split-view open, and thread titles (best-effort)
ASSISTANT_GREETING=👋 Hi! Ask me anything to get started.
# Starter prompts (max 4 used). NOTE: on the current agent surface these render only
# if agent_view.suggested_prompts is ALSO filled in your Slack app manifest — this
# env list feeds the legacy assistant_thread_started path.
ASSISTANT_SUGGESTED_PROMPTS=What's trending in food & beverage right now?,Summarize this document for me,Generate an image of …

# --- Output hygiene (Phase 3.4) ---
SELF_PREFIX_NAMES=ChatGPT,ChatGPT-Dev,Assistant,Bot  # Leading "Name:" prefixes stripped from replies so the bot never answers as "ChatGPT: …"

# =====================================================================
# 3) MODELS & FEATURES — safe to adjust; changes what the bot does.
# Channel participation & UX (Claude-parity features): GLOBAL DEFAULTS
# live here. Per-channel overrides are set in Slack via the "⚙️ Configure"
# footer button under bot responses (the DB is storage only, not the
# config UI). Comma-separated lists trim whitespace and drop empty entries.
# =====================================================================

# Model Configuration
GPT_MODEL=gpt-5.6-sol  # Default model. Supported: gpt-5.6-sol (flagship), gpt-5.6-terra (balanced), gpt-5.6-luna (fast), gpt-5.5
GPT_IMAGE_MODEL=gpt-image-2  # Default image generation model: gpt-image-2 (latest), gpt-image-1 (legacy). Per-user override available in /settings.
UTILITY_MODEL=gpt-5.6-luna  # Model for intent classification and utilities

# Default Text Generation Parameters
DEFAULT_TEMPERATURE=1.0  # 0.0-2.0 (only honored with REASONING_EFFORT=none; reasoning calls are fixed at 1.0)
DEFAULT_MAX_TOKENS=32768  # Maximum output tokens per response
DEFAULT_TOP_P=1.0  # 0.0-1.0, nucleus sampling (only honored with REASONING_EFFORT=none)

# Reasoning Parameters
# Effort ladder: none/low/medium/high/xhigh/max on the 5.6 family; gpt-5.5 tops out at xhigh.
# "minimal" is a 400 on both. temp/top_p are only honored when effort=none.
DEFAULT_REASONING_EFFORT=low  # Default reasoning effort level
DEFAULT_VERBOSITY=low  # low/medium/high - Response detail level

# Image Generation Parameters (gpt-image-2 / gpt-image-1)
DEFAULT_IMAGE_SIZE=1024x1024  # 1024x1024/1024x1536/1536x1024/auto — valid on both models; gpt-image-2 also accepts arbitrary WxH (multiples of 16, aspect ≤3:1, up to 3840x2160)
DEFAULT_IMAGE_QUALITY=auto  # auto/low/medium/high - affects cost and detail
DEFAULT_IMAGE_BACKGROUND=auto  # auto/transparent/opaque (gpt-image-2 doesn't support transparent — coerced to auto)
DEFAULT_IMAGE_NUMBER=1  # Number of images to generate
DEFAULT_IMAGE_FORMAT=png  # png/jpeg/webp - output format (transparent backgrounds need png or webp)
DEFAULT_IMAGE_COMPRESSION=100  # PNG requires 100, JPEG/WebP can be less
DEFAULT_INPUT_FIDELITY=high  # high/low - high preserves original style in edits (gpt-image-1 only; gpt-image-2 auto-handles fidelity)

# Vision Parameters
DEFAULT_DETAIL_LEVEL=auto  # auto/low/high - Vision analysis detail

# Web Search Configuration
ENABLE_WEB_SEARCH=true  # Enable/disable web search functionality
WEB_SEARCH_MODEL=  # Leave empty to use GPT_MODEL

# MCP (Model Context Protocol) Configuration
MCP_ENABLED_DEFAULT=true  # Enable MCP by default for new users
MCP_CONFIG_PATH=mcp_config.json  # Path to MCP server configuration file
# MCP server secrets: never put API keys directly in mcp_config.json.
# Define any variable here (any name you like) and reference it in
# mcp_config.json as ${YOUR_VAR_NAME} — placeholders are expanded from the
# environment at load time; a server with unresolved placeholders is skipped
# with a warning. Example:
#   MY_MCP_API_KEY=sk-your-key-here          (here in .env)
#   "X-API-Key": "${MY_MCP_API_KEY}"         (in mcp_config.json headers)

# Streaming & response UX toggles
ENABLE_STREAMING=true  # Enable streaming responses (Global - All Bot Platforms)
SLACK_STREAMING=true  # Enable streaming specifically for Slack
SLACK_NATIVE_STREAMING=false  # Native chat.startStream/appendStream/stopStream. DEFAULT OFF: capability built+tested but wire+validate live before enabling.
ENABLE_ASSISTANT_STATUS=true  # assistant.threads.setStatus "thinking/working" indicator (best-effort; no-ops in plain channels)
ENABLE_PROGRESS_CHECKLIST=true  # Accumulating "✓ done / loader active" checklist on image-pipeline status messages (off → single-line status + rotator)
PROGRESS_CHECKLIST_PREFER_MESSAGE=true  # Image checklists post a real visible thread message even where Slack's assistant-status surface exists (dual display: message + composer status); off → degrade to composer status alone
ENABLE_WAKE_ENVELOPE=true  # Tell the model WHY it woke (trigger reason, sender role, bot-vs-human) via a compact block in the volatile developer suffix
ENABLE_BACKGROUND_IMAGE_GEN=true  # Run new-image generation in a background job so the thread lock releases and chat keeps flowing (off → inline generation holds the lock)
ENABLE_FEEDBACK_BUTTONS=true  # 👍/👎 feedback buttons under DM/assistant responses (channels use reactions)

# --- Reactions (Phase 4) ---
ENABLE_REACTIONS=true  # Allow the bot to answer with an emoji reaction
REACTION_EMOJIS=thumbsup,eyes,white_check_mark,raised_hands,tada,thinking_face,+1  # Vetted reaction emoji (names, no colons)
REACTION_MAX_PER_MESSAGE=4  # Max distinct emoji the bot may place on a single message (F6)

# --- Channel listening (Phase 5/6) ---
ENABLE_CHANNEL_LISTENING=false  # MASTER SWITCH. OFF = only @mentions + DMs (no behavior change). ON = see/act on channel messages.
CHANNEL_RESPONSE_MODE=tag_only  # Global default channel mode: tag_only | auto_respond | off (per-channel override via the Configure footer button)
BOT_NAME_ALIASES=ChatGPT  # Names the bot wakes to without an @ (case-insensitive whole word). SET PER ENV, e.g. ChatGPT-Dev in dev.
REPLY_IN_CHANNEL_DEFAULT=true  # Channels with no saved setting: may the bot answer top-level messages at channel level? (It judges per message; per-channel setting overrides.)

# --- ParticipationEngine (redesign Phase F) ---
# Judgment layer for UNPROMPTED channel participation (levels: off | mentions_only | judicious | active;
# legacy modes map off≡off, tag_only≡mentions_only, auto_respond≡judicious; per-channel via Configure).
ENABLE_PARTICIPATION_ENGINE=true  # false = unaddressed channel messages ignored with zero model cost (mentions unaffected)
PARTICIPATION_DEBOUNCE_SECONDS=3  # Rapid-fire messages in a channel collapse to ONE engine evaluation of the latest state
MAX_UNPROMPTED_REPLIES_PER_HOUR=6  # Hard rail per channel; "active" level gets 2x; mentions never throttled
PARTICIPATION_SNOOZE_HOURS=4  # "Butt out" snooze length (unprompted participation off; @mentions still work)
SNOOZE_ACK_EMOJI=zipper_mouth_face  # Reaction that acknowledges a backoff request without more words

# --- Local function-call loop (redesign Phase A) ---
ENABLE_TOOL_LOOP=true  # Master switch for model-invoked local tools (history fetch, reactions, later search/memory)
ENABLE_REACT_TOOL=true  # Model may add emoji reactions mid-response (react_to_message; allowlist = REACTION_EMOJIS)
ENABLE_NO_REPLY_TOOL=true  # On unprompted (participation-gated) turns, expose no_response_needed so the bot can stay silent explicitly instead of posting filler
ENABLE_TOOL_PROVENANCE=true  # Remember which tools the bot used each turn (names + arg gists) and reinject a "[used tools: …]" note so it can recall its own past tool use (F7; off → nothing captured/annotated)
ENABLE_TOOL_RESULT_MEMORY=true  # Additionally remember MCP call OUTPUTS and reinject a "[tool results: <server> → <digest>]" block so the bot can reuse a prior result (links/figures/titles) instead of re-querying and retracting (F12; MCP only, rides on F7 — effective only when ENABLE_TOOL_PROVENANCE is on)
TOOL_RESULT_DIGEST_CHARS=2000  # Per-call cap on a stored MCP result digest (chars); longer outputs are truncated with a "… [truncated]" marker (F12)
TOOL_RESULT_TURN_CHARS=6000  # Per-turn total budget for MCP result digests (chars, first-come order); calls past the cap store no digest (F12)
ENABLE_MESSAGE_TIMESTAMPS=true  # Prefix every message in model context with a deterministic local timestamp ("[Fri 2026-07-10 9:17 PM EDT]") from its Slack ts in the sender's timezone, so the model can reason about time gaps (F10; off → content byte-identical to before)

# --- On-demand history-fetch tools (Phase 8) ---
ENABLE_HISTORY_TOOLS=true  # Privacy-scoped Slack history-fetch tools (model-invoked via the tool loop)

# --- Slack search tool (redesign Phase B) ---
ENABLE_SEARCH_TOOL=true  # search_slack via assistant.search.context (needs an action token from the triggering event)
SEARCH_CHANNEL_TYPES=public_channel,private_channel  # Code-level bound on searchable surfaces; add im/mpim ONLY if the bot should search DMs (needs search:read.im/mpim scopes)

# --- Per-channel memory (Phase 9) ---
ENABLE_CHANNEL_MEMORY=true  # Inject durable channel facts into the prompt + model-invoked remember/update/forget tools
MEMORY_MAX_ROWS=25  # Max channel-scope memory rows per channel (remember_fact refuses at the cap)
ENABLE_MEMORY_EXTRACTION_FALLBACK=false  # Legacy post-response extraction pass (one utility call per exchange); superseded by the memory tools

# --- Document architecture (Phase D2) ---
# The DB never stores document content: rows are summary + metadata + Slack CDN ref.
# Full content is re-derived in memory on demand (read_document tool) — deleting a file
# in Slack genuinely removes its content from the bot's reach.
ENABLE_NATIVE_FILE_INPUT=true  # PDFs within limits ride the attach turn as native input_file parts (model sees text + rendered pages; higher token cost than plain text)
NATIVE_FILE_MAX_PAGES=100      # API ceiling per request; larger PDFs use local extraction
NATIVE_FILE_MAX_MB=32          # API ceiling per request; larger PDFs use local extraction
ENABLE_READ_DOCUMENT_TOOL=true # Model-invoked on-demand document access (download + extract in memory)

# --- Per-channel settings entry point (Phase 7) ---
ENABLE_RESPONSE_FOOTER=true  # Append one compact "⚙️ <model>" button under each channel response; ANY member opens the per-channel settings modal. No slash command / no manifest change (interactivity already enabled).

# --- Vision question enhancement (legacy hop) ---
# OFF by default: frontier vision models answer the user's question directly. Turning this on
# restores the old behavior — a gpt-5-mini call rewrites the question (re-sending full
# conversation history) before every vision analysis, costing one utility call + 1-2s latency.
ENABLE_VISION_ENHANCEMENT=false

# =====================================================================
# 4) ADVANCED TUNING — don't touch unless you know what you're doing;
#    changes how (well/fast/cheap) the bot does it
# =====================================================================

# Model Token Limits (verified context window sizes; >272K input bills at 2x input/1.5x output on 5.5/5.6)
GPT54_MAX_TOKENS=1050000  # GPT-5.6 family (Sol/Terra/Luna) + GPT-5.5 context window (1.05M) — env var name kept for compatibility
GPT54_TOKEN_BUFFER_PERCENTAGE=0.876  # ~920k usable of 1.05M (~130k reserved: 32.8k output cap + estimator/tool/doc headroom)
GPT5_MAX_TOKENS=400000  # Fallback window for unknown/legacy models (e.g. gpt-5-mini)

# Token Management Configuration
TOKEN_BUFFER_PERCENTAGE=0.875  # Fallback-model buffer: 350k usable of 400k
TOKEN_CLEANUP_THRESHOLD=0.9  # Start thread compaction at 90% of buffered limit
TOKEN_TRIM_MESSAGE_COUNT=5  # Messages evaluated per compaction pass (internal batch size)
TOKEN_COMPACTION_TARGET=0.7  # Compact down to 70% of the limit in one pass (chunky compaction preserves OpenAI prefix caching; the dropped span rolls into the thread summary)

# Utility Function Parameters (intent classification, quick checks)
UTILITY_REASONING_EFFORT=none  # For quick checks, intent classification ("none" = zero reasoning tokens)
UTILITY_VERBOSITY=low  # For utility functions
UTILITY_MAX_TOKENS=500  # Max output tokens for utility responses (higher reasoning effort needs a higher cap or intent classification will fail)
PARTICIPATION_REASONING_EFFORT=low  # Channel participation judgment only — needs light reasoning to resolve who "you" means in multi-party threads; sits behind the debounce, not the response critical path

# Analysis Function Parameters (vision analysis, complex tasks)
ANALYSIS_REASONING_EFFORT=medium  # For vision analysis, complex tasks
ANALYSIS_VERBOSITY=medium  # For analysis tasks
VISION_MAX_TOKENS=32768  # Higher limit for vision + reasoning tasks

# Streaming timing & circuit breaker
STREAMING_UPDATE_INTERVAL=1.0  # Seconds between streaming updates (Slack Workspace API Limit, tier 3 allows ~50 requests per minute per workspace per method)
STREAMING_MIN_INTERVAL=1.0  # Minimum seconds between updates (Slack limit)
STREAMING_MAX_INTERVAL=30.0  # Maximum seconds allowed for streaming updates
STREAMING_BUFFER_SIZE=500  # Characters to buffer before forcing update
STREAMING_CIRCUIT_BREAKER_THRESHOLD=3  # Failed chunks before disabling streaming
STREAMING_CIRCUIT_BREAKER_COOLDOWN=60  # Seconds before re-enabling after failure

# API Timeout Configuration - (Images, vision, high reasoning, take a while - allow enough time for responses to begin to return)
API_TIMEOUT_READ=180.0  # Seconds - General API timeout (hard limit). Image gen/edit have their own longer budget below.
API_TIMEOUT_STREAMING_CHUNK=270.0  # Seconds - Timeout for streaming chunks (Setting this too low will cause the bot to drop entire responses early)
API_TIMEOUT_IMAGE=300  # Seconds - Dedicated timeout for image generation/edit (applied as both the outer wait_for and the per-request SDK timeout)
SOCKET_LIVENESS_TIMEOUT=600  # Seconds without any inbound Socket Mode envelope before the liveness monitor logs (ERROR if ping-pong is also frozen = presumed dead; WARNING once per episode if pings still fresh). Detection only, never reconnects. 0 disables (F9)

# ParticipationEngine / ChannelPulse internals
# --- ChannelPulse ambient awareness (redesign Phase E) ---
ENABLE_CHANNEL_PULSE=true  # Per-channel in-memory ring of recent messages (inert while listening is off)
CHANNEL_PULSE_SIZE=30  # Ring size per channel (messages); backfilled once per channel per process
CHANNEL_PULSE_ENVELOPE_MAX=15  # Max "[Recent channel activity]" lines injected with channel responses (0 = envelope off)
PARTICIPATION_THREAD_TAIL=6  # Per-thread messages the participation classifier sees for addressee resolution (F5; 0 disables)
PULSE_THREAD_TAILS_MAX=50  # Max distinct threads whose tails are retained per channel (whole-thread LRU)
PULSE_THREAD_TAIL_CHANNELS_MAX=30  # Global bound on channels retaining thread-tail rings (outer-map LRU)

# --- Conversational queueing (redesign Phase Q; busy rejection retired) ---
QUEUE_DRAIN_LINGER_SECONDS=1.0  # Wait after a turn ends so straggler messages join the same catch-up batch
QUEUE_MAX_BATCH=10  # Max queued messages answered in ONE catch-up turn; the rest drain next turn
QUEUE_MAX_PENDING=25  # Hard bound per conversation; beyond this messages drop from warm context (recovered from Slack on refetch)

# Tool-loop execution caps
MAX_TOOL_ROUNDS=4  # Max tool-execution rounds per response (on cap, the model must answer with what it has)
MAX_TOOL_CALLS_PER_TURN=8  # Max total local tool calls per response
TOOL_CALL_TIMEOUT=20  # Seconds per tool execution; a timeout returns an error result to the model
TOOL_RESULT_MAX_CHARS=20000  # Truncation cap on a single tool result fed back to the model
HISTORY_TOOL_MAX_MESSAGES=50  # Hard cap on messages returned per history-fetch call
DOC_EXTRACTION_CACHE_SIZE=20  # Process-lifetime LRU of extracted text (never persisted)

# Cleanup Configuration (cron format)
CLEANUP_SCHEDULE=0 0 * * *  # Daily at midnight (cron format)
CLEANUP_MAX_AGE_HOURS=24  # Remove threads older than this

# Logging Configuration
BOT_LOG_LEVEL=INFO  # DEBUG/INFO/WARNING/ERROR/CRITICAL
SLACK_LOG_LEVEL=INFO  # Slack client logging level
UTILS_LOG_LEVEL=INFO  # Utilities logging level
CONSOLE_LOGGING_ENABLED=TRUE  # Enable/disable console output
LOG_DIRECTORY=logs  # Directory for log files

# Database Configuration
DATABASE_DIR=data  # Directory for database files and backups
