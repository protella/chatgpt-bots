{
  "mcpServers": {

    "context7": {
      "server_url": "https://mcp.context7.com/mcp",
      "server_description": "Library documentation and code examples",
      "require_approval": "never"
    },

    "my-api-with-bearer-auth": {
      "server_url": "https://api.example.com/mcp",
      "server_description": "Your API description here. Secrets belong in .env - ${VAR_NAME} placeholders are expanded from the environment at load time.",
      "require_approval": "never",
      "headers": {
        "Authorization": "Bearer ${MY_API_TOKEN}"
      }
    },

    "my-api-with-custom-header": {
      "server_url": "https://api.example.com/mcp",
      "server_description": "API using custom header auth. Set \"enabled\": false to skip a server without deleting its config.",
      "require_approval": "never",
      "enabled": true,
      "headers": {
        "X-API-Key": "${MY_OTHER_API_KEY}"
      }
    },

    "restricted-tools-example": {
      "server_url": "https://database.example.com/mcp",
      "server_description": "Database with restricted tool access",
      "require_approval": "never",
      "headers": {
        "Authorization": "Bearer YOUR_TOKEN"
      },
      "allowed_tools": ["query_data", "search"]
    }

  }
}
